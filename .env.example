# Supabase / Lovable Cloud (publishable values — safe in client)
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"

# Server-only Supabase config (do NOT commit real values)
SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"

# PayPal — publishable Client ID is safe in client.
# The PAYPAL_SECRET is server-only and must be set via your hosting/secrets manager, never committed.
VITE_PAYPAL_CLIENT_ID="your-paypal-client-id"

# Server-only secrets (managed via Lovable Cloud / hosting env — never committed):
# PAYPAL_CLIENT_ID=
# PAYPAL_SECRET=
# PAYPAL_ENV=sandbox            # set to "live" for production
# YOUTUBE_API_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# LOVABLE_API_KEY=
